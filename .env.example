# Copy to ".env" and fill in. Never commit ".env".

# Server-only (used by Vite dev / preview middleware — not exposed to the browser)
MIDTRANS_SERVER_KEY=Mid-server-YourServerKeyHere

# Public (embedded in client bundle)
VITE_MIDTRANS_CLIENT_KEY=Mid-client-YourClientKeyHere

# "true" = production Midtrans hosts; omit or "false" for sandbox
VITE_MIDTRANS_PRODUCTION=false

# Admin WhatsApp in international format without + (e.g. 6281234567890)
VITE_ADMIN_WHATSAPP_E164=6281234567890
