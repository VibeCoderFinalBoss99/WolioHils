# =============================================================================
# Salin ke .env lokal. Di Vercel: Settings → Environment Variables (nama = kolom kiri).
# =============================================================================

# --- Midtrans ---
MIDTRANS_SERVER_KEY=
VITE_MIDTRANS_CLIENT_KEY=
VITE_MIDTRANS_PRODUCTION=false

# --- Supabase ---
# Project URL: https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Hanya untuk backend Vercel (Serverless / Edge) — tanpa prefix VITE_
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard ---
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=

# Opsional
# VITE_ADMIN_WHATSAPP_E164=6281234567890
# VITE_WOLIO_STORE_API=
