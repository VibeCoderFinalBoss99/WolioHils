# =============================================================================
# Monorepo WolioHills — taruh .env di ROOT repo (dibaca packages/public & admin).
# Vercel: set variabel yang sama di masing-masing project (publik vs admin).
# =============================================================================

# --- Midtrans (hanya packages/public + API snap) ---
# Server key & client key harus dari merchant & mode yang SAMA (Sandbox ↔ sandbox, Production ↔ production).
MIDTRANS_SERVER_KEY=
VITE_MIDTRANS_CLIENT_KEY=
# Opsional di Vercel untuk API server: sama nilainya dengan baris bawah bila VITE_* tidak tersedia di runtime.
MIDTRANS_PRODUCTION=false
VITE_MIDTRANS_PRODUCTION=false

# --- Supabase ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
# Wajib untuk packages/public di Vercel: upsert booking dari situs tamu (bukan VITE_*).
# Harus JWT **service_role** dari Supabase (secret), BUKAN anon public — kalau tertukar → "permission denied for table bookings".
SUPABASE_SERVICE_ROLE_KEY=

# --- Publik ---
VITE_ADMIN_WHATSAPP_E164=

# --- Admin (Supabase Auth email/password; promote role di SQL) ---
# Tidak perlu VITE_ADMIN_USERNAME — gunakan Supabase Dashboard → Authentication.
